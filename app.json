{
  "expo": {
    "name": "Netsoko",
    "slug": "sokonet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#070a13"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sokonet.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#070a13"
      },
      "package": "com.sokonet.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "sokonet",
    "updates": {
      "url": "https://u.expo.dev/sokonet"
    },
    "extra": {
      "eas": {
        "projectId": "sokonet-project-id"
      }
    }
  }
}
